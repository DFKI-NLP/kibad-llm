{
  "version": 1,
  "disable_existing_loggers": false,

  "formatters": {
    "vllm": {
      "class": "vllm.logging_utils.NewLineFormatter",
      "datefmt": "%m-%d %H:%M:%S",
      "format": "%(levelname)s %(asctime)s [%(filename)s:%(lineno)d] %(message)s"
    }
  },

  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "formatter": "vllm",
      "level": "INFO",
      "stream": "ext://sys.stdout"
    },
    "stats_file": {
      "class": "logging.handlers.RotatingFileHandler",
      "formatter": "vllm",
      "level": "INFO",
      "filename": "vllm-stats.log",
      "maxBytes": 10485760,
      "backupCount": 5
    }
  },

  "loggers": {
    "vllm": {
      "handlers": ["console"],
      "level": "INFO",
      "propagate": false
    },

    "vllm.v1.metrics.loggers": {
      "handlers": ["stats_file"],
      "level": "INFO",
      "propagate": false
    },

    "vllm.engine.metrics": {
      "handlers": ["stats_file"],
      "level": "INFO",
      "propagate": false
    }
  }
}
