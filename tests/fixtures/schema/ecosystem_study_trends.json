{
  "$defs": {
    "BiodiversityTrend": {
      "additionalProperties": false,
      "description": "Biodiversitätstrend bestehend aus Organismengruppe (taxa), Lebensraum (habitat),\nBiodiversitätsvariable (biodiversity_variable) und Trendrichtung (trend_category).",
      "properties": {
        "taxa": {
          "$ref": "#/$defs/TaxaRoteListe",
          "description": "Auf welche Organismengruppe bezieht sich der Trend?"
        },
        "habitat": {
          "$ref": "#/$defs/HabitatForTrendEnum",
          "description": "Auf welchen der folgenden Lebensräume bezieht sich der Trend?"
        },
        "biodiversity_variable": {
          "$ref": "#/$defs/BiodiversityVariableEnum",
          "description": "Mithilfe welcher Biodiversitätsvariable wird der Trend gemessen?"
        },
        "trend_category": {
          "$ref": "#/$defs/TrendCategoryEnum",
          "description": "In welche der folgenden Kategorien lässt sich die Richtung des Trends einordnen?"
        }
      },
      "required": [
        "taxa",
        "habitat",
        "biodiversity_variable",
        "trend_category"
      ],
      "title": "BiodiversityTrend",
      "type": "object"
    },
    "BiodiversityVariableEnum": {
      "enum": [
        "Abundanz",
        "Artenzahl",
        "ENS"
      ],
      "title": "BiodiversityVariableEnum",
      "type": "string"
    },
    "HabitatForTrendEnum": {
      "enum": [
        "AgrarOffen",
        "Binnengewaesser",
        "Boden",
        "Kueste",
        "Urban",
        "Wald"
      ],
      "title": "HabitatForTrendEnum",
      "type": "string"
    },
    "HauptGruppeRoteListenEnum": {
      "enum": [
        "Makrofauna",
        "Mesofauna",
        "Mikrofauna",
        "Pflanzen",
        "Pilze_Flechten",
        "Wirbellose",
        "Wirbeltiere"
      ],
      "title": "HauptGruppeRoteListenEnum",
      "type": "string"
    },
    "TaxaRoteListe": {
      "additionalProperties": false,
      "description": "Organismengruppe mit Hauptgruppe (hauptgruppe_rote_listen), Untergruppe (untergruppe_rote_listen)\nund Detail (untergruppe_rote_listen_detail).",
      "properties": {
        "hauptgruppe_rote_listen": {
          "$ref": "#/$defs/HauptGruppeRoteListenEnum",
          "description": "Hauptgruppe der Organismen"
        },
        "untergruppe_rote_listen": {
          "anyOf": [
            {
              "$ref": "#/$defs/UntergruppeRoteListenEnum"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Untergruppe der Organismen"
        },
        "untergruppe_rote_listen_detail": {
          "anyOf": [
            {
              "$ref": "#/$defs/UntergruppeRoteListenDetailEnum"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Detaillierte Organismengruppe"
        }
      },
      "required": [
        "hauptgruppe_rote_listen"
      ],
      "title": "TaxaRoteListe",
      "type": "object"
    },
    "TrendCategoryEnum": {
      "enum": [
        "positive",
        "negative",
        "no",
        "positive to negative",
        "negative to positive"
      ],
      "title": "TrendCategoryEnum",
      "type": "string"
    },
    "UntergruppeRoteListenDetailEnum": {
      "enum": [
        "Amphibien",
        "Andere",
        "Andere_Wirbellose",
        "Arthropoden",
        "Bakterien",
        "Binnenmollusken",
        "Bodenmikroorganismen",
        "Chiroptera/ Fledermaeuse",
        "Doppelfüßer",
        "Enchytraeidae",
        "Farn- und Blütenpflanzen",
        "Fische",
        "Flechten",
        "Gamasina",
        "Heuschrecken",
        "Hornmilben (Oribatida)",
        "Kurzflügler",
        "Käfer, Wanzen, Zikaden",
        "Landschnecken",
        "Laufkäfer",
        "Libellen",
        "Makrofauna",
        "Makrophyten",
        "Makrozoobenthos",
        "Microbes",
        "Mikroorganismen",
        "Mollusken",
        "Moose",
        "Nematoda",
        "Nematoden",
        "Oribatida",
        "Pflanzen",
        "Phytoplankton",
        "Pilze",
        "Regenwürmer",
        "Reptilien",
        "saprophage Nematoden",
        "Spechte und zusätzlich Fledermäuse (Säugetiere)",
        "Spinnen",
        "Säuger",
        "Säugetiere",
        "Süßwasserfische",
        "Tagfalter",
        "Tardigrada",
        "Unken",
        "Vögel",
        "Waldvegetation",
        "Waldvegetation, Wasser- und Ufervegetation",
        "Wasser- und Ufervegetation",
        "Zooplankton"
      ],
      "title": "UntergruppeRoteListenDetailEnum",
      "type": "string"
    },
    "UntergruppeRoteListenEnum": {
      "enum": [
        "Amphibien",
        "Andere_Wirbellose",
        "Andere_Wirbellose_Makrozoobenthos",
        "Andere_Wirbellose_Zooplankton",
        "Arthropoden",
        "Collembola",
        "Fische",
        "Flechten",
        "Mesostigmata",
        "Mikroalgen",
        "Moose",
        "Oribatida",
        "Pflanzen",
        "Pilze",
        "Reptilien",
        "Saeuger",
        "Voegel"
      ],
      "title": "UntergruppeRoteListenEnum",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Angaben zu den im Text beschriebenen Biodiversitätstrends.",
  "properties": {
    "trends": {
      "description": "Liste der im Text beschriebenen Biodiversitätstrends.",
      "items": {
        "$ref": "#/$defs/BiodiversityTrend"
      },
      "title": "Trends",
      "type": "array"
    }
  },
  "title": "EcosystemStudyTrends",
  "type": "object"
}