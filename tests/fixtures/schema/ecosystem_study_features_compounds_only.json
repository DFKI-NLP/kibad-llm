{
  "$defs": {
    "EcosystemType": {
      "additionalProperties": false,
      "description": "Ökosystemtyp mit Kategorie und Term.",
      "properties": {
        "category": {
          "$ref": "#/$defs/EcosystemTypeCategoryEnum",
          "description": "Kategorie des Biotoptyps"
        },
        "term": {
          "$ref": "#/$defs/EcosystemTypeTermEnum",
          "description": "Spezifischer Biotoptyp"
        }
      },
      "required": [
        "category",
        "term"
      ],
      "title": "EcosystemType",
      "type": "object"
    },
    "EcosystemTypeCategoryEnum": {
      "enum": [
        "I Biotoptypengruppen der Meere und Küsten",
        "II Biotoptypengruppen der Binnengewässer",
        "III Terrestrische und semiterrestrische Biotoptypengruppen des Binnenlandes",
        "IV Technische Biotoptypengruppen",
        "V Biotoptypengruppen mit Schwerpunkt in den Alpen",
        "VI Weitere"
      ],
      "title": "EcosystemTypeCategoryEnum",
      "type": "string"
    },
    "EcosystemTypeTermEnum": {
      "enum": [
        "Anthropogene Rohbodenstandorte und Ruderalfluren",
        "Bauwerke",
        "Benthal der Nordsee",
        "Benthal der Ostsee",
        "Feldgehölze, Gebüsche, Hecken und Gehölzkulturen",
        "Fels- und Steilküsten",
        "Felsen, Block- und Schutthalden, Geröllfelder, offene Bereiche mit sandigem oder bindigem Substrat",
        "Fließende Gewässer",
        "Gebirgsrasen (subalpine bis alpine Stufe)",
        "Grundwasser und Höhlengewässer",
        "Grün- und Freiflächen",
        "Hoch-, Zwischen- und Übergangsmoore",
        "Höhlen (einschließlich Stollen, Brunnenschächte etc.)",
        "Kleine, unbefestigte Freiflächen des besiedelten Bereiches",
        "Küstendünen",
        "Laub(Misch)Wälder und -Forste (Laubbaumanteil über 50 Prozent)",
        "Nadel(Misch)Wälder und -Forste",
        "Pelagial der Nordsee",
        "Pelagial der Ostsee",
        "Quellen (inklusive Quellabfluss (Krenal))",
        "Röhrichte (ohne Brackwasserröhrichte)",
        "Salzgrünland der Nordseeküste (Supralitoral)",
        "Salzgrünland, Brackwasserröhrichte und -Hochstaudenfluren des Geolitorals der Ostseeküste",
        "Stehende Gewässer",
        "Sände, Sand-, Geröll- und Blockstrände",
        "Trockenrasen sowie Grünland trockener bis frischer Standorte",
        "Verkehrsanlagen und Plätze",
        "Wald- und Ufersäume, Staudenfluren",
        "Waldfreie Niedermoore und Sümpfe, Grünland nasser bis feuchter Standorte",
        "Waldmäntel und Vorwälder, spezielle Waldnutzungsformen",
        "Zwergstrauchheiden",
        "Äcker und Ackerbrachen"
      ],
      "title": "EcosystemTypeTermEnum",
      "type": "string"
    },
    "Location": {
      "additionalProperties": false,
