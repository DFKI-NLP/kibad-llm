{
  "$defs": {
    "HabitatEnum": {
      "enum": [
        "Agrar- und Offenland",
        "Binnengewässer und Auen",
        "Boden",
        "Küsten und Küstengewässer",
        "Urbane Räume",
        "Wald"
      ],
      "title": "HabitatEnum",
      "type": "string"
    },
    "SpeciesGroupForTrendEnum": {
      "enum": [
        "Amphibien",
        "Arthropoden",
        "Fische",
        "Flechten",
        "Mikroalgen",
        "Pflanzen",
        "Pilze",
        "Reptilien",
        "Säuger",
        "Übrige Wirbellose",
        "Vögel"
      ],
      "title": "SpeciesGroupForTrendEnum",
      "type": "string"
    },
    "TaxaForTrend": {
      "additionalProperties": false,
      "description": "Art mit wissenschaftlichem und deutschem Namen sowie taxonomischer Gruppe.",
      "properties": {
        "scientific_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Wissenschaftlicher Name der Art",
          "title": "Scientific Name"
        },
        "german_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Deutscher Name der Art",
          "title": "German Name"
        },
        "species_group": {
          "$ref": "#/$defs/SpeciesGroupForTrendEnum",
          "description": "Taxonomische Gruppe der Art"
        }
      },
      "required": [
        "species_group"
      ],
      "title": "TaxaForTrend",
      "type": "object"
    },
    "TrendCategoryEnum": {
      "enum": [
        "positive",
        "negative",
        "no",
        "positive to negative",
        "negative to positive"
      ],
      "title": "TrendCategoryEnum",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Biodiversitätstrend bestehend aus Artengruppe (taxa), Lebensraum (habitat),\nBiodiversitätsvariable (biodiversity_variable) und Trendrichtung (trend_category).",
  "properties": {
    "taxa": {
      "$ref": "#/$defs/TaxaForTrend",
      "description": "Auf welche Artengruppe bezieht sich der Trend?"
    },
    "habitat": {
      "$ref": "#/$defs/HabitatEnum",
      "description": "Auf welchen der folgenden Lebensräume bezieht sich der Trend?"
    },
    "biodiversity_variable": {
      "description": "Mithilfe welcher Biodiversitätsvariable wird der Trend gemessen?",
      "title": "Biodiversity Variable",
      "type": "string"
    },
    "trend_category": {
      "$ref": "#/$defs/TrendCategoryEnum",
      "description": "In welche der folgenden Kategorien lässt sich die Richtung des Trends einordnen?"
    }
  },
  "required": [
    "taxa",
    "habitat",
    "biodiversity_variable",
    "trend_category"
  ],
  "title": "BiodiversityTrend",
  "type": "object"
}